---
import "../styles/global.css";
import type { ImageMetadata } from "astro";
import FallbackImage from "../assets/blog-placeholder-1.jpg";
import { SITE_TITLE, url } from "../consts";

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const { title, description, image = FallbackImage } = Astro.props;

const fontBase = import.meta.env.BASE_URL.replace(/\/$/, "");
const fontFaceCSS = `
@font-face {
  font-family: "Atkinson";
  src: url("${fontBase}/fonts/atkinson-regular.woff") format("woff");
  font-weight: 400;
  font-style: normal;
  font-display: swap;
}
@font-face {
  font-family: "Atkinson";
  src: url("${fontBase}/fonts/atkinson-bold.woff") format("woff");
  font-weight: 700;
  font-style: normal;
  font-display: swap;
}
`;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/png" sizes="32x32" href={url("/logo.png")} />
<link rel="icon" type="image/png" sizes="192x192" href={url("/logo.png")} />
<link rel="apple-touch-icon" href={url("/logo.png")} />
<link rel="sitemap" href={url("/sitemap-index.xml")} />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL("rss.xml", Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Font preloads -->
<link
	rel="preload"
	href={url("/fonts/atkinson-regular.woff")}
	as="font"
	type="font/woff"
	crossorigin
/>
<link
	rel="preload"
	href={url("/fonts/atkinson-bold.woff")}
	as="font"
	type="font/woff"
	crossorigin
/>
<!-- Font face declarations with correct base path -->
<style set:html={fontFaceCSS}></style>

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image.src, Astro.url)} />
<meta property="og:locale" content="es_BO" />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image.src, Astro.url)} />
