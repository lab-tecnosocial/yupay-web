---
import { Image } from "astro:assets";
import Logo from "../assets/logo.png";
import { url } from "../consts";
import HeaderLink from "./HeaderLink.astro";
---

<header>
	<nav>
		<a href={url("/")} class="logo-link">
			<Image src={Logo} alt="Yupay" height={108} quality={100} />
		</a>
		<div class="nav-links">
			<HeaderLink href="/">Inicio</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/aprende">Aprende</HeaderLink>
			<HeaderLink href="/estadisticas">Estadísticas</HeaderLink>
			<HeaderLink href="/about">Nosotros</HeaderLink>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		margin: 0;
		padding: 0 1.5em;
		background: white;
		border-bottom: 3px solid var(--yupay-yellow);
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1100px;
		margin: 0 auto;
		height: 64px;
	}
	.logo-link {
		display: flex;
		align-items: center;
		text-decoration: none;
		flex-shrink: 0;
	}
	.logo-link img {
		border-radius: 0;
		height: 36px;
		width: auto;
	}
	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.25em;
	}
	.nav-links :global(a) {
		padding: 0.5em 0.75em;
		border-radius: 6px;
	}
	.nav-links :global(a:hover),
	.nav-links :global(a.active) {
		background-color: #fff8e6;
	}
	@media (max-width: 720px) {
		header {
			padding: 0 0.5em;
			overflow: hidden;
		}
		nav {
			gap: 0.25em;
		}
		.nav-links {
			gap: 0;
			flex-shrink: 1;
			overflow: hidden;
		}
		.nav-links :global(a) {
			padding: 0.35em 0.35em;
			font-size: 0.78em;
		}
	}
</style>
